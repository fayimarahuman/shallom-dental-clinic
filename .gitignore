archive.zip
archive/
*.csv

# OS / editor junk
.DS_Store
Thumbs.db
.vscode/
.idea/

# Streamlit local config/secrets (if you ever use .streamlit/secrets.toml)
.streamlit/secrets.toml

# Logs
*.log